alias cd.='cd ..'

alias ls='ls --color'
alias ll='ls --color -lh'
alias la='ls --color -lAh'

alias grep='grep --color'
alias fgrep='fgrep --color'
alias egrep='egrep --color'

alias vi='vim'
alias r='ranger'

# .dotfiles repository alias
alias dotfiles='/usr/bin/git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'
